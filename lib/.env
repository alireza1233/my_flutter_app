API_URL=http://localhost:8080/api/v1
API_URL_PICTURES=http://localhost:8080/static/media
RECAPTCHA_SITE_KEY=dummy
BYPASS_CAPTCHA=true

GOOGLE_AUTH_URL=/auth/google
